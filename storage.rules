rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Book cover images — public read, write only via signed URLs (generated by Cloud Function)
    match /books/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    // Experience images — public read, write only via signed URLs
    match /experiences/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    // Everything else is locked
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
